  "clauses": {
    "WHERE": {
      "syntax": "WHERE {field} {op} {value}",
      "can_repeat": 2,
      "semantics": "AND across multiple WHERE predicates",
      "field_source": "result_type + enrichment_fields",
      "op_source": "operators"
    },
    "HAVING": {
      "syntax": "HAVING {field} {op} {value}",
      "can_repeat": 2,
      "semantics": "AND across multiple HAVING predicates, applied after GROUP BY",
      "requires": "GROUP_BY",
      "field_source": "result_type",
      "op_source": "operators"
    },
    "IN": {
      "syntax": "IN '{glob}'",
      "can_repeat": 0,
      "value_pool": "globs"
    },
    "EXCLUDE": {
      "syntax": "EXCLUDE '{glob}'",
      "can_repeat": 0,
      "value_pool": "globs"
    },
    "ORDER_BY": {
      "syntax": "ORDER BY {field} [{direction}]",
      "can_repeat": 0,
      "field_source": "result_type + enrichment_fields",
      "directions": [
        "ASC",
        "DESC"
      ],
      "default_direction": "DESC"
    },
    "GROUP_BY": {
      "syntax": "GROUP BY {field}",
      "can_repeat": 0,
      "field_source": "result_type.string_fields"
    },
    "LIMIT": {
      "syntax": "LIMIT {n}",
      "can_repeat": 0,
      "value_pool": "limit_values"
    },
    "OFFSET": {
      "syntax": "OFFSET {n}",
      "can_repeat": 0,
      "value_pool": "offset_values"
    },
    "DEPTH": {
      "syntax": "DEPTH {n}",
      "can_repeat": 0,
      "value_pool": "depth_values",
      "applies_to": [
        "show_body",
        "show_context",
        "find_files"
      ]
    },
    "LINES": {
      "syntax": "LINES {n}",
      "can_repeat": 0,
      "value_pool": "lines_values",
      "applies_to": [
        "show_context"
      ]
    }
  },
