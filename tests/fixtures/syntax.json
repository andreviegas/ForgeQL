{
  "meta": {
    "version": "1.0",
    "description": "ForgeQL grammar state machine — single source of truth for combinatorial test generation (SMS)",
    "seed": 42,
    "total_budget": 1000,
    "clause_pipeline_order": [
      "IN",
      "EXCLUDE",
      "WHERE",
      "GROUP_BY",
      "HAVING",
      "ORDER_BY",
      "OFFSET",
      "LIMIT"
    ],
    "notes": [
      "Parser accepts clauses in any order; engine applies them in pipeline order above.",
      "can_repeat: 0 = max 1 occurrence, N = max N occurrences per command.",
      "explosion_cap: per-command ceiling — walker stops generating for this command type after N commands.",
      "total_budget: global ceiling — walker stops entirely after N commands total (CI-friendly).",
      "seed: deterministic RNG seed — same seed always produces identical command set.",
      "result_type links a command to the set of fields available for WHERE/ORDER BY/GROUP BY."
    ],
    "generation_strategy": {
      "description": "Two-phase generation ensures broad coverage within the total_budget.",
      "phase1_baseline": "Generate one command per (command_id × clause) pair. Every command type, every clause type, and every operator appears at least once. This guarantees breadth.",
      "phase2_random_fill": "Fill remaining budget with seeded random clause combinations, respecting per-command explosion_cap. Provides depth and edge-case coverage.",
      "invariant": "phase1 count <= total_budget. If total_budget is too small for full baseline, phase1 round-robins across commands to maximize breadth."
    }
  },
