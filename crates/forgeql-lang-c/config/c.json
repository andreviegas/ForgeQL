{
  "language": {
    "name": "c",
    "extensions": ["c"],
    "tree_sitter_grammar": "tree-sitter-c"
  },

  "definitions": {
    "function_kinds": ["function_definition"],
    "type_kinds": ["struct_specifier", "enum_specifier", "union_specifier"],
    "definition_kinds": [
      "function_definition",
      "struct_specifier",
      "enum_specifier",
      "union_specifier"
    ],
    "declaration_kinds": ["declaration"],
    "field_kinds": ["field_declaration"],
    "parameter_kind": "parameter_declaration",
    "member_body_kind": "field_declaration_list",
    "member_kinds": ["field_declaration"],
    "owner_container_kinds": ["struct_specifier", "union_specifier"],
    "nested_function_body_kinds": ["function_definition"],
    "constant_def_parent_kinds": ["preproc_def", "enumerator", "init_declarator"]
  },

  "syntax": {
    "root_node": "translation_unit",
    "scope_separator": "::",
    "block": "compound_statement",
    "scope_creating_kinds": ["compound_statement"],
    "identifier": "identifier",
    "parameter_list": "parameter_list",
    "declarator_field": "declarator",
    "function_declarator": "function_declarator",
    "init_declarator": "init_declarator",
    "comment": "comment",
    "skip_node_kinds": [],
    "usage_node_kinds": ["identifier", "field_identifier", "type_identifier"],
    "statement_boundary_kinds": [
      "expression_statement",
      "if_statement",
      "while_statement",
      "for_statement",
      "switch_statement",
      "do_statement",
      "return_statement",
      "break_statement",
      "continue_statement",
      "goto_statement",
      "declaration"
    ],
    "loop_kinds": ["for_statement", "while_statement", "do_statement"],
    "exception_handler_kinds": []
  },

  "control_flow": {
    "kinds": [
      "if_statement",
      "while_statement",
      "for_statement",
      "switch_statement",
      "do_statement"
    ],
    "switch_kinds": ["switch_statement"],
    "for_style_map": [
      ["for_statement", "traditional"]
    ],
    "condition_clause": "condition",
    "branch_kinds": [
      "if_statement",
      "else_clause",
      "for_statement",
      "while_statement",
      "do_statement",
      "switch_statement",
      "case_statement"
    ],
    "loop_kinds": ["for_statement", "while_statement", "do_statement"],
    "exception_handler_kinds": []
  },

  "statements": {
    "return": "return_statement",
    "break": "break_statement",
    "goto": "goto_statement",
    "case": "case_statement",
    "assignment_kinds": ["assignment_expression"],
    "update_kinds": ["update_expression"]
  },

  "expressions": {
    "call": "call_expression",
    "binary": "binary_expression",
    "unary": "unary_expression",
    "field_access": "field_expression",
    "subscript": "subscript_expression",
    "parenthesized": "parenthesized_expression",
    "comma": "comma_expression",
    "address_of": "pointer_expression",
    "address_of_operator": "&",
    "shift_kinds": ["shift_expression"],
    "compound_assignment": "compound_assignment"
  },

  "types": {
    "type_descriptor": "type_descriptor",
    "array_declarator": "array_declarator",
    "enumerator": "enumerator"
  },

  "literals": {
    "number_kinds": ["number_literal"],
    "string_kinds": ["string_literal", "char_literal"],
    "string_content_kind": "string_content",
    "char_kind": "char_literal",
    "null_values": ["NULL", "0"],
    "boolean_values": ["true", "false"],
    "digit_separator": "'",
    "number_suffixes": [
      ["ull", "unsigned_long_long"],
      ["ul", "unsigned_long"],
      ["ll", "long_long"],
      ["uz", "unsigned_size"],
      ["u", "unsigned"],
      ["l", "long"],
      ["z", "size"],
      ["f", "float"]
    ]
  },

  "modifiers": {
    "map": [
      ["const", "is_const"],
      ["static", "is_static"],
      ["inline", "is_inline"],
      ["extern", "is_extern"],
      ["volatile", "is_volatile"],
      ["restrict", "is_restrict"]
    ],
    "node_kinds": [
      "type_qualifier",
      "storage_class_specifier"
    ],
    "static_storage_keywords": ["static"]
  },

  "casts": [
    ["cast_expression", "c_style", "unsafe"]
  ],

  "comments": {
    "prefixes": [
      ["/**", "doc_block"],
      ["/*", "block"],
      ["//", "line"]
    ]
  },

  "capabilities": {
    "has_goto": true,
    "has_increment_decrement": true,
    "has_implicit_truthiness": true
  },

  "guards": {
    "block_guard_kinds": ["preproc_ifdef", "preproc_if"],
    "elif_kinds": ["preproc_elif"],
    "else_kinds": ["preproc_else"],
    "condition_field": "condition",
    "name_field": "name",
    "negate_ifdef_variant": "#ifndef"
  },

  "macros": {
    "def_markers": ["#define"],
    "def_kinds": ["preproc_function_def", "preproc_def"],
    "invocation_kind": "macro_invocation",
    "parameters_field": "parameters",
    "value_field": "value"
  },

  "kind_map": {
    "function_definition": "function",
    "shift_expression": "shift_expression",
    "struct_specifier": "struct",
    "enum_specifier": "enum",
    "declaration": "variable",
    "parameter_declaration": "variable",
    "field_declaration": "field",
    "comment": "comment",
    "preproc_include": "import",
    "preproc_def": "macro",
    "preproc_function_def": "macro",
    "type_definition": "type_alias",
    "number_literal": "number",
    "cast_expression": "cast",
    "update_expression": "increment",
    "compound_assignment": "compound_assignment",
    "if_statement": "if",
    "while_statement": "while",
    "for_statement": "for",
    "switch_statement": "switch",
    "do_statement": "do",
    "macro_invocation": "macro_call"
  }
}
