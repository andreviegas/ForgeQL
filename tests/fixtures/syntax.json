  "assertion_tiers": {
    "description": "Three tiers of validation, applied progressively by the SMS harness.",
    "tier1_parse": {
      "description": "Command must parse without error. Validates grammar coverage.",
      "applies_to": "all commands"
    },
    "tier2_no_crash": {
      "description": "Parsed command must execute without panic. May return error result (e.g., symbol not found).",
      "applies_to": "all commands",
      "requires_session": true
    },
    "tier3_invariants": {
      "description": "Result must satisfy invariants derived from the parsed IR clauses.",
      "applies_to": "query and show commands",
      "requires_session": true,
      "checks": [
        {
          "clause": "LIMIT",
          "invariant": "result.count <= limit_value"
        },
        {
          "clause": "OFFSET",
          "invariant": "first result index >= offset_value"
        },
        {
          "clause": "IN",
          "invariant": "all result paths match IN glob"
        },
        {
          "clause": "EXCLUDE",
          "invariant": "no result paths match EXCLUDE glob"
        },
        {
          "clause": "WHERE",
          "invariant": "all results satisfy predicate (field op value)"
        },
        {
          "clause": "ORDER_BY",
          "invariant": "results are sorted by field in declared direction"
        },
        {
          "clause": "GROUP_BY",
          "invariant": "no duplicate values in GROUP BY field"
        }
      ]
    }
  },
