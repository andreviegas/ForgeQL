{
  "language": {
    "name": "xml",
    "extensions": ["xml", "arxml", "xdm", "epc", "epd", "ecuc", "odx"],
    "tree_sitter_grammar": "tree-sitter-xml"
  },

  "syntax": {
    "root_node": "document",
    "skip_node_kinds": []
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "element": "object",
    "Comment": "comment"
  }
}
