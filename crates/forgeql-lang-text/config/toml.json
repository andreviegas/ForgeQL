{
  "language": {
    "name": "toml",
    "extensions": ["toml", "lock"],
    "tree_sitter_grammar": "tree-sitter-toml"
  },

  "syntax": {
    "root_node": "document",
    "skip_node_kinds": []
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "table": "object",
    "table_array_element": "object",
    "pair": "pair",
    "array": "array",
    "inline_table": "object",
    "comment": "comment"
  }
}
