{
  "language": {
    "name": "dbc",
    "extensions": ["dbc"],
    "tree_sitter_grammar": "tree-sitter-dbc"
  },

  "syntax": {
    "root_node": "dbc_file",
    "skip_node_kinds": []
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "message": "object",
    "signal": "field",
    "value_table": "enum",
    "value_descriptions_for_signal": "enum",
    "attribute_definition": "pair",
    "attribute_value_for_object": "pair",
    "environment_variable": "variable",
    "comment": "comment"
  }
}
