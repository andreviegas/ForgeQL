{
  "language": {
    "name": "json",
    "extensions": ["json", "jsonc"],
    "tree_sitter_grammar": "tree-sitter-json"
  },

  "syntax": {
    "root_node": "document",
    "skip_node_kinds": []
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "object":  "object",
    "array":   "array",
    "pair":    "pair",
    "comment": "comment"
  }
}