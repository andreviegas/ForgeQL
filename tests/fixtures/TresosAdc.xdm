<?xml version='1.0'?>
<datamodel version="7.0"
           xmlns="http://www.tresos.de/_projects/DataModel2/16/root.xsd"
           xmlns:a="http://www.tresos.de/_projects/DataModel2/16/attribute.xsd"
           xmlns:v="http://www.tresos.de/_projects/DataModel2/06/schema.xsd"
           xmlns:d="http://www.tresos.de/_projects/DataModel2/06/data.xsd">
  <d:ctr type="AUTOSAR" factory="autosar">
    <d:lst type="TOP-LEVEL-PACKAGES">
      <d:ctr name="TS_T16D27M4I0R0" type="AR-PACKAGE">
        <d:lst type="ELEMENTS">
          <d:chc name="Adc" type="AR-ELEMENT" value="MODULE-CONFIGURATION">
            <d:ctr type="MODULE-CONFIGURATION">
              <a:a name="DEF" value="ASPath:/TS_T16D27M4I0R0/Adc"/>
              <d:var name="IMPLEMENTATION_CONFIG_VARIANT" type="ENUMERATION" value="VariantPreCompile"/>
              <d:lst name="AdcConfigSet" type="MAP">
                <d:ctr name="AdcConfigSet_0" type="IDENTIFIABLE">
                  <d:lst name="AdcHwUnit" type="MAP">
                    <d:ctr name="AdcHwUnit_0" type="IDENTIFIABLE">
                      <d:var name="AdcHwUnitId" type="ENUMERATION" value="ADC0"/>
                      <d:var name="AdcPrescale" type="INTEGER" value="4"/>
                      <d:lst name="AdcChannel" type="MAP">
                        <d:ctr name="AdcChannel_0" type="IDENTIFIABLE">
                          <d:var name="AdcChannelId" type="INTEGER" value="0"/>
                          <d:var name="AdcChannelResolution" type="INTEGER" value="12"/>
                        </d:ctr>
                        <d:ctr name="AdcChannel_1" type="IDENTIFIABLE">
                          <d:var name="AdcChannelId" type="INTEGER" value="3"/>
                          <d:var name="AdcChannelResolution" type="INTEGER" value="10"/>
                        </d:ctr>
                      </d:lst>
                    </d:ctr>
                  </d:lst>
                </d:ctr>
              </d:lst>
              <d:ctr name="AdcGeneral" type="IDENTIFIABLE">
                <d:var name="AdcDevErrorDetect" type="BOOLEAN" value="true"/>
                <d:var name="AdcGrpNotifCapability" type="BOOLEAN" value="false"/>
              </d:ctr>
            </d:ctr>
          </d:chc>
        </d:lst>
      </d:ctr>
    </d:lst>
  </d:ctr>
</datamodel>
