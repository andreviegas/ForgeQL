{
  "language": {
    "name": "cmake",
    "extensions": ["cmake", "cmakelists.txt"],
    "tree_sitter_grammar": "tree-sitter-cmake"
  },

  "syntax": {
    "root_node": "source_file",
    "skip_node_kinds": []
  },

  "definitions": {
    "function_kinds": ["function_def", "macro_def"]
  },

  "control_flow": {
    "kinds": ["if_condition", "foreach_loop", "while_loop"],
    "for_style_map": [["foreach_loop", "range"]]
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "function_def": "function",
    "macro_def": "macro",
    "normal_command": "call_statement",
    "if_condition": "if",
    "foreach_loop": "for",
    "while_loop": "while",
    "block_def": "object",
    "line_comment": "comment",
    "bracket_comment": "comment"
  }
}
