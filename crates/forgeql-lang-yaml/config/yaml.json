{
  "language": {
    "name": "yaml",
    "extensions": ["yaml", "yml"],
    "tree_sitter_grammar": "tree-sitter-yaml"
  },

  "syntax": {
    "root_node": "stream",
    "skip_node_kinds": []
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "block_mapping_pair": "pair",
    "flow_pair":          "pair",
    "block_mapping":      "object",
    "flow_mapping":       "object",
    "block_sequence":     "array",
    "flow_sequence":      "array",
    "comment":            "comment"
  }
}