    "expect_lines": [
      {"line": 51, "text": "static ALWAYS_INLINE void *thread_runq(struct k_thread *thread)"},
      {"line": 64, "text": "\treturn &_kernel.cpus[cpu].ready_q.runq;"},
      {"line": 67, "text": "\treturn &_kernel.ready_q.runq;"},
      {"line": 71, "text": "static ALWAYS_INLINE void *curr_cpu_runq(void)"},
      {"line": 74, "text": "\treturn &arch_curr_cpu()->ready_q.runq;"}
    ]
  },
  {
    "name": "G7_show_lines_matches_filter",
    "fql": "SHOW LINES 51-75 OF 'kernel/sched.c' WHERE text MATCHES 'void \\*\\w+_runq'",
