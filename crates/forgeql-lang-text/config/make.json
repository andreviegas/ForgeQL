{
  "language": {
    "name": "make",
    "extensions": ["mk", "makefile", "gnumakefile"],
    "tree_sitter_grammar": "tree-sitter-make"
  },

  "syntax": {
    "root_node": "makefile",
    "skip_node_kinds": []
  },

  "definitions": {
    "function_kinds": ["rule"]
  },

  "control_flow": {
    "kinds": ["conditional"]
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "rule": "function",
    "variable_assignment": "variable",
    "shell_assignment": "variable",
    "define_directive": "macro",
    "include_directive": "import",
    "conditional": "if",
    "comment": "comment"
  }
}
