{
  "language": {
    "name": "just",
    "extensions": ["just", "justfile"],
    "tree_sitter_grammar": "tree-sitter-just"
  },

  "syntax": {
    "root_node": "source_file",
    "skip_node_kinds": []
  },

  "capabilities": {
    "has_goto": false,
    "has_increment_decrement": false,
    "has_implicit_truthiness": false,
    "params_share_body_scope": false
  },

  "kind_map": {
    "recipe": "function",
    "assignment": "variable",
    "alias": "variable",
    "setting": "pair",
    "module": "namespace",
    "import": "import",
    "comment": "comment"
  }
}
